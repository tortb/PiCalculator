#!/bin/bash

# π计算器便捷启动脚本
# 用法：java-pi <位数> [输出文件名]
# 示例：java-pi 1000000
#       java-pi 1000000 pi_result.md

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [ $# -lt 1 ]; then
    echo "π计算器 - 高性能π值计算工具"
    echo ""
    echo "用法：java-pi <位数> [输出文件名]"
    echo ""
    echo "示例:"
    echo "  java-pi 100          # 计算 100 位π"
    echo "  java-pi 1000000      # 计算 100 万位π"
    echo "  java-pi 1000000 out.md"
    echo ""
    echo "常用位数:"
    echo "  100        - 快速测试"
    echo "  1000       - 基础测试"
    echo "  10000      - 常规精度"
    echo "  100000     - 高精度"
    echo "  1000000    - 超高精度"
    exit 0
fi

# 确保 jar 文件存在
if [ ! -f "$SCRIPT_DIR/PiCalculator.jar" ]; then
    echo "错误：未找到 PiCalculator.jar"
    echo "正在编译项目..."
    cd "$SCRIPT_DIR" && ./build.sh
    if [ $? -ne 0 ]; then
        echo "编译失败！"
        exit 1
    fi
fi

# 自动检测系统可用内存
get_available_memory() {
    local avail=$(free -m | awk '/^Mem:/{print $7}')
    echo $avail
}

# 根据位数计算合适的堆大小
calculate_heap_size() {
    local digits=$1
    local avail_mem=$2
    
    # 基础内存 1GB
    local base_mem=1024
    
    # 根据位数估算额外内存 (每 100 万位约需 100MB)
    local extra_mem=$((digits / 1000000 * 100))
    
    # 计算所需内存
    local needed=$((base_mem + extra_mem))
    
    # 使用可用内存的 70%
    local max_use=$((avail_mem * 70 / 100))
    
    # 取较小值，但至少有 256MB
    if [ $max_use -lt 256 ]; then
        max_use=256
    fi
    
    if [ $needed -lt $max_use ]; then
        echo $needed
    else
        echo $max_use
    fi
}

AVAIL_MEM=$(get_available_memory)
HEAP_SIZE=$(calculate_heap_size $1 $AVAIL_MEM)

# 确保堆大小在合理范围内
if [ $HEAP_SIZE -lt 256 ]; then
    HEAP_SIZE=256
elif [ $HEAP_SIZE -gt 16384 ]; then
    HEAP_SIZE=16384
fi

# 设置 JVM 参数
JAVA_OPTS="-Xms${HEAP_SIZE}M -Xmx${HEAP_SIZE}M -XX:+UseG1GC -XX:+AlwaysPreTouch"

# 内存充足时启用 NUMA
if [ $HEAP_SIZE -gt 4096 ] && [ -f /sys/devices/system/node/possible ]; then
    JAVA_OPTS="$JAVA_OPTS -XX:+UseNUMA"
fi

exec java $JAVA_OPTS -jar "$SCRIPT_DIR/PiCalculator.jar" "$@"
